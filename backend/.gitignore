# Create .gitignore
$gitignore = @'
# Backend
backend/target/
backend/.idea/
backend/*.log
backend/.mvn/wrapper/maven-wrapper.jar

# Frontend
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
'@

$gitignore | Out-File -FilePath ".gitignore" -Encoding UTF8